#### ---------------------------- AUDIO PIPELINE ENVIRONMENT VARIABLES ---------------------------- ####
HUGGING_FACE_TOKEN=

# device: cpu or cuda for NVIDIA GPU
DEVICE=cpu  

# leave MODEL_SIZE_TRT empty if not using TensorRT
MODEL_SIZE_TRT=

# MODEL_SIZE Options: tiny, base, small, medium, large-v2, large-v3
MODEL_SIZE=base

# Optional custom cache path for pyannote models
PYANNOTE_CACHE_DIR=

# 0 is false (use online model), 1 is true (use offline model)
USE_OFFLINE_MODELS=0 

# 0 is false (don't install MEDCAT software), 1 is true (install MEDCAT software)
ENABLE_MEDCAT=0

# 0 is false (use local environment), 1 is true (use Docker container)
AUTOGEN_USE_DOCKER=0 

#### ---------------------------- VIDEO PIPELINE ENVIRONMENT VARIABLES ---------------------------- ####
# Pipeline configuration (video)

# Source images directory
PIPELINE_DETECTION_SOURCE=data/video/source_files

# Central pipeline output root
PIPELINE_ROOT=data/video/output_files
PIPELINE_DETECTION_OUTPUT=data/video/output_files/DetectionOutput
PIPELINE_CLASSIFICATION_OUTPUT=data/video/output_files/ClassificationOutput

# Detection parameters
PIPELINE_DETECTION_MODEL=MnLgt/yolo-human-parse
PIPELINE_MAX_IMAGES=200
PIPELINE_ADD_HEAD=true
PIPELINE_ALPHA_PNG=false
PIPELINE_MIN_AREA=250
PIPELINE_MARGIN=0.10
PIPELINE_CLASSES=face,arm,hand,leg,foot,neck,torso,head
PIPELINE_DEBUG=false

# Crop filename parsing
# Crops are named like: <origstem>_<body_part>_<idx>.jpg
# This controls which token is interpreted as body-part label (default -2 => <body_part>).
PIPELINE_BODY_PART_LABEL_POSITION=-2

# Injury classification (run a wound/injury classifier checkpoint on detection crops)
PIPELINE_INJURY_CHECKPOINT=checkpoints/classificationModel/injury/best_swin_tiny_patch4_window7_224.pt
PIPELINE_INJURY_IMG_SIZE=224
PIPELINE_INJURY_BATCH_SIZE=32
PIPELINE_INJURY_NUM_WORKERS=0
PIPELINE_INJURY_REPORT_JSON=data/video/output_files/ClassificationOutput/injury_predictions.json
PIPELINE_INJURY_REPORT_CSV=data/video/output_files/ClassificationOutput/injury_predictions_summary.csv


#### ---------------------------- APRILTAG DETECTION ENVIRONMENT VARIABLES ---------------------------- ####

# Tag Detection Settings

# Type of tag (0-29)
TAG_FAMILY=tag16h5
# in meters (3 cm)
TAG_SIZE=0.03
TARGET_TAG_IDS=0


# Detection Performance - For fine tuning performance
NTHREADS=4
QUAD_DECIMATE=1.0

#### ---------------------------- IMAGE CAPTURE ENVIRONMENT VARIABLES ---------------------------- ####

SNAPSHOT_INTERVAL = 2