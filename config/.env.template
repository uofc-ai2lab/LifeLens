#### ---------------------------- TRANSCRIPTION ENVIRONMENT VARIABLES ---------------------------- ####
HUGGINGFACE_TOKEN=your_hf_token_here

# device: cpu or cuda for NVIDIA GPU
DEVICE=cpu  

# leave MODEL_SIZE_TRT empty if not using TensorRT
MODEL_SIZE_TRT= 

# MODEL_SIZE Options: tiny, base, small, medium, large-v2, large-v3
MODEL_SIZE=  

# Optional custom cache path for pyannote models
PYANNOTE_CACHE_DIR=

# 0 is false (use online model), 1 is true (use offline model)
USE_OFFLINE_MODELS=0 

# Audio files being transcribe, remove any not in use
AUDIO_FILES=

# Directory to save transcription files - if left blank, defaults to ./data/transcript_files
TRANSCRIPT_DIR= 

#### ---------------------------- MEANING EXTRACTION ENVIRONMENT VARIABLES ---------------------------- ####
# Transcription files being extracted for meaning, remove any not in use
TRANSCRIPT_FILES=

# Directory to save transcription files - if left blank, defaults to ./data/meaning_files
MEANING_DIR= 

ENABLE_SEMANTIC_FILTERING=1

OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_key_here
# 0 is false (use local environment), 1 is true (use Docker container)
AUTOGEN_USE_DOCKER=0 